    {
      "content" : [
        {
          "anchor" : "overview",
          "level" : 2,
          "text" : "Overview",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "In a heap, elements are ordered sequentially, with parents appearing before their children. All parents but the last",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "have 2 children (the last parent may contain 1 child). Ordering is determined by a function given during",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "initialization.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "Apple’s swift-collections package contains a min-max heap implementation that may be better to use. I have not",
                  "type" : "text"
                },
                {
                  "text" : " ",
                  "type" : "text"
                },
                {
                  "text" : "measured and compared performance of either.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "Note",
          "style" : "note",
          "type" : "aside"
        },
        {
          "inlineContent" : [
            {
              "text" : "Creating a new heap is straightforward:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "var heap: PriorityQueue<Int> = .init(ordering: \\<)"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Since ",
              "type" : "text"
            },
            {
              "code" : "Int",
              "type" : "codeVoice"
            },
            {
              "text" : " conforms to the ",
              "type" : "text"
            },
            {
              "code" : "Orderable",
              "type" : "codeVoice"
            },
            {
              "text" : " protocol, one can omit the ",
              "type" : "text"
            },
            {
              "code" : "ordering:",
              "type" : "codeVoice"
            },
            {
              "text" : " argument if a min-heap of integers is desired:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "var heap: PriorityQueue<Int> = .init()"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "For a max heap, one must provide ",
              "type" : "text"
            },
            {
              "code" : "\\>",
              "type" : "codeVoice"
            },
            {
              "text" : " operator or use the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/maxOrdering(_:)",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " factory function.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "To add values to a heap, call the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/push(_:)",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " method. This method supports a variable number of values",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "(there is the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/push(items:)",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " variant for a sequence):",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "heap.push(6, 5, 7)",
            "heap.push(items: [8, 3, 4])",
            "heap.popAll() # -> [3, 4, 5, 6, 7, 8]"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "To fetch the min\/max item from the queue, use the ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/pop()",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " method:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "let value = heap.pop()"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "It is acceptable to call this even if the queue is empty – the return value will be ",
              "type" : "text"
            },
            {
              "code" : "nil",
              "type" : "codeVoice"
            },
            {
              "text" : " when that is the case.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "There is also a non-destructive ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/first",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " attribute which returns the min\/max item in the queue (or ",
              "type" : "text"
            },
            {
              "code" : "nil",
              "type" : "codeVoice"
            },
            {
              "text" : " if queue",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "is empty).",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "anchor" : "Not-a-Sequence",
          "level" : 3,
          "text" : "Not a Sequence",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Note that the queue does not conform to ",
              "type" : "text"
            },
            {
              "code" : "Sequence",
              "type" : "codeVoice"
            },
            {
              "text" : ", nor to ",
              "type" : "text"
            },
            {
              "code" : "IteratorProtocol",
              "type" : "codeVoice"
            },
            {
              "text" : ". There is however a",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/forEach(block:)",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " method that one can use to repeatedly obtain the “top” element in the queue until it",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "is empty:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "var heap: PriorityQueue<Int> = .init(1, 9, 3, 5)",
            "var tops: [Int] = []",
            "heap.forEach {",
            "  tops.append($0)",
            "}"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Similarly, there is a ",
              "type" : "text"
            },
            {
              "identifier" : "doc:\/\/PriorityQueue\/documentation\/PriorityQueue\/PriorityQueue\/popAll()",
              "isActive" : true,
              "type" : "reference"
            },
            {
              "text" : " method that returns an array of the ordered elements from the queue:",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "code" : [
            "var heap: PriorityQueue<Int> = .init(1, 7, 3, 5)",
            "let tops = heap.popAll() # -> [1, 3, 5, 7]"
          ],
          "syntax" : null,
          "type" : "codeListing"
        },
        {
          "inlineContent" : [
            {
              "text" : "Both of these are destructive operations, leaving the queue empty.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
